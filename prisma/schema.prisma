generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./seospark.db"
}

model Content {
  id        String   @id @default(cuid())
  sessionId String
  title     String
  keywords  String
  body      String
  type      String   @default("blog")
  createdAt DateTime @default(now())
}
